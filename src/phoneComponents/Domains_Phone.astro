---
---
    <style>
        .domains-mobile-section {
            min-height: 100vh;
            background: url('/glow_ball_red.svg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: scroll;
            position: relative;
            padding: 2rem 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .mobile-section-subtitle {
            color: #fefcd9;
            text-align: center;
            font-family: 'PolySans Trial', sans-serif;
            font-size: 16px;
            font-weight: 400;
            max-width: 90%;
            margin-bottom: 3rem;
            line-height: 1.5;
        }

        .domains-mobile-grid {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            width: 100%;
            max-width: 400px;
            align-items: center;
        }

        .mobile-domain-item {
            width: 100%;
            max-width: 300px;
            cursor: pointer;
            transition: transform 0.3s ease, opacity 0.3s ease;
        }

        .mobile-domain-item:hover {
            transform: scale(1.05);
        }

        .mobile-cassette-img {
            width: 100%;
            height: auto;
            display: block;
            filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
            border-radius: 20px;
        }

        /* Staggered animation entrance */
        .mobile-domain-item {
            opacity: 0;
            transform: translateY(30px);
            animation: slideInUp 0.6s ease forwards;
        }

        .mobile-domain-item:nth-child(1) { animation-delay: 0.1s; }
        .mobile-domain-item:nth-child(2) { animation-delay: 0.2s; }
        .mobile-domain-item:nth-child(3) { animation-delay: 0.3s; }
        .mobile-domain-item:nth-child(4) { animation-delay: 0.4s; }
        .mobile-domain-item:nth-child(5) { animation-delay: 0.5s; }
        .mobile-domain-item:nth-child(6) { animation-delay: 0.6s; }

        @keyframes slideInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .mobile-section-subtitle {
            opacity: 0;
            animation: fadeIn 0.8s ease forwards;
            animation-delay: 0.3s;
        }

        @keyframes fadeIn {
            to {
                opacity: 1;
            }
        }
    </style>

<section class="domains-mobile-section">
    <p class="mobile-section-subtitle">
        <span style="display:block; margin-bottom: 0.5rem;">
            Each domain at ACM-VIT is more than a skillset — it's a mindset.
        </span>
        <span style="display:block; margin-bottom: 0.5rem;">
            We build, break, design, analyze, and communicate — not in silos, but in sync.
        </span>
        <span style="display:block;">
            Because true innovation happens where disciplines intersect.
        </span>
    </p>

    <div class="domains-mobile-grid">
        <div class="mobile-domain-item" data-domain="app">
            <img src="/Cassette_App.svg" alt="App Development" class="mobile-cassette-img" />
        </div>
        <div class="mobile-domain-item" data-domain="cc">
            <img src="/Cassette_cc.svg" alt="Competitive Coding" class="mobile-cassette-img" />
        </div>
        <div class="mobile-domain-item" data-domain="design">
            <img src="/Cassette_Design.svg" alt="Design" class="mobile-cassette-img" />
        </div>
        <div class="mobile-domain-item" data-domain="management">
            <img src="/Cassette_Management.svg" alt="Management" class="mobile-cassette-img" />
        </div>
        <div class="mobile-domain-item" data-domain="research">
            <img src="/Cassette_Research.svg" alt="Research" class="mobile-cassette-img" />
        </div>
        <div class="mobile-domain-item" data-domain="web">
            <img src="/Cassette_Web.svg" alt="Web Development" class="mobile-cassette-img" />
        </div>
    </div>
</section>

<script>
    import { domainConfigs } from '../data/domainsData';

    // Mobile-optimized domain screen functionality
    function initMobileAnimation() {
        const items = document.querySelectorAll('.mobile-domain-item');
        
        items.forEach((item) => {
            // Add click event handler for domain screen
            item.addEventListener('click', () => {
                const domain = item.getAttribute('data-domain');
                if (domain) {
                    showMobileDomainScreen(domain);
                }
            });

            // Add touch feedback
            item.addEventListener('touchstart', () => {
                (item as HTMLElement).style.transform = 'scale(0.95)';
            });

            item.addEventListener('touchend', () => {
                (item as HTMLElement).style.transform = 'scale(1)';
            });
        });
    }

    // Function to show mobile domain screen
    function showMobileDomainScreen(domain: string) {
        const config = domainConfigs[domain as keyof typeof domainConfigs];
        if (!config) return;

        // Hide all cassettes with animation
        const items = document.querySelectorAll('.mobile-domain-item');
        const subtitle = document.querySelector('.mobile-section-subtitle');
        const domainsSection = document.querySelector('.domains-mobile-section');
        
        // Create smooth exit animation for cassettes
        items.forEach((item, index) => {
            setTimeout(() => {
                (item as HTMLElement).style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                (item as HTMLElement).style.opacity = '0';
                (item as HTMLElement).style.transform = 'translateY(-20px) scale(0.9)';
            }, index * 50);
        });

        // Hide subtitle
        if (subtitle) {
            setTimeout(() => {
                (subtitle as HTMLElement).style.transition = 'opacity 0.3s ease';
                (subtitle as HTMLElement).style.opacity = '0';
            }, 100);
        }

        // Create mobile domain screen HTML after cassettes fade
        setTimeout(() => {
            const mobileDomainScreenHTML = createMobileDomainScreenContent(config);

            // Insert the domain screen
            const domainScreenDiv = document.createElement('div');
            domainScreenDiv.id = 'mobile-domain-screen';
            domainScreenDiv.className = 'fixed inset-0 z-50 overflow-y-auto';
            domainScreenDiv.style.scrollbarWidth = 'none';
            (domainScreenDiv.style as any).msOverflowStyle = 'none';
            domainScreenDiv.innerHTML = mobileDomainScreenHTML;
            
            // Add webkit scrollbar hiding
            const style = document.createElement('style');
            style.textContent = `
                #mobile-domain-screen::-webkit-scrollbar {
                    display: none;
                }
            `;
            document.head.appendChild(style);
            
            document.body.appendChild(domainScreenDiv);

            // Mobile entrance animation
            (domainScreenDiv as HTMLElement).style.opacity = '0';
            (domainScreenDiv as HTMLElement).style.transform = 'translateY(20px)';
            
            setTimeout(() => {
                (domainScreenDiv as HTMLElement).style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                (domainScreenDiv as HTMLElement).style.opacity = '1';
                (domainScreenDiv as HTMLElement).style.transform = 'translateY(0)';
            }, 10);
        }, 400);
    }

    // Function to create mobile domain screen content
    function createMobileDomainScreenContent(config: any) {
        const themeColors = {
            app: "#9B51E0",
            web: "#B4E35B", 
            design: "#FF7777",
            research: "#9AF3FF",
            management: "#008080",
            competitive: "#42CD9D"
        };

        const themeHex = themeColors[config.themeColor as keyof typeof themeColors] || themeColors.app;

        return `
            <div class="min-h-screen text-white" style="background-color: #000000; background-image: url('/background_pattern.svg'); background-size: cover; background-position: center; background-repeat: no-repeat;">
                <!-- Mobile Back Button -->
                <div class="fixed top-4 right-4 z-50">
                    <button 
                        onclick="hideMobileDomainScreen()"
                        class="relative w-10 h-10 flex items-center justify-center hover:opacity-80 transition-opacity"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 50 50" fill="none" class="absolute">
                            <circle cx="25" cy="25" r="19.5" stroke="#FEFCD9"/>
                        </svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="relative z-10">
                            <path d="M3 19V5" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M13 6L7 12L13 18" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M7 12H21" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>

                <!-- Mobile Hero Section with Theme Header -->
                <div class="pt-16 pb-8 px-4">
                    <!-- Mobile Main Title Card -->
                    <div class="mx-auto max-w-xs mb-8 relative">
                        <!-- Mobile SVG Background -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100" viewBox="0 0 300 100" fill="none" class="w-full">
                            <path d="M50 1.5H250C275.41 1.5 296 22.09 296 47.5V52.5C296 77.91 275.41 98.5 250 98.5H50C24.59 98.5 4 77.91 4 52.5V47.5C4 22.09 24.59 1.5 50 1.5Z" fill="${themeHex}" stroke="#FEFCD9" stroke-width="3"/>
                        </svg>
                        
                        <!-- Mobile Content overlay -->
                        <div class="absolute inset-0 flex items-center justify-center p-3">
                            <!-- Mobile Decorative Elements -->
                            <div class="absolute left-3 top-1/2 -translate-y-1/2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 124 124" fill="none" class="animate-spin" style="animation-duration: 8s;">
                                    <circle cx="62" cy="62" r="57.5" stroke="#1E1E1E" stroke-width="3"/>
                                    <path d="M61.6582 18C67.7102 18 73.4766 19.2231 78.7246 21.4336L73.4238 30.6182L82.9629 36.126L88.2588 26.9512C97.4504 33.9379 103.81 44.4557 105.314 56.4844H94.7051V67.5H105.316C103.815 79.5413 97.4473 90.0689 88.2441 97.0586L82.9473 87.8828L73.4082 93.3906L78.709 102.572C73.4651 104.779 67.7043 106 61.6582 106C55.6035 106 49.8348 104.776 44.585 102.563L49.8945 93.3672L40.3555 87.8594L35.0527 97.0439C25.8603 90.0541 19.5005 79.5326 18 67.5H28.6123V56.4844H18.002C19.5071 44.4491 25.8735 33.9262 35.0732 26.9395L40.3721 36.1172L49.9121 30.6104L44.6094 21.4258C49.8527 19.2199 55.6129 18.0001 61.6582 18Z" fill="#1E1E1E"/>
                                </svg>
                            </div>
                            
                            <div class="absolute right-3 top-1/2 -translate-y-1/2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 124 124" fill="none" class="animate-spin" style="animation-duration: 8s;">
                                    <circle cx="62" cy="62" r="57.5" stroke="#1E1E1E" stroke-width="3"/>
                                    <path d="M61.6582 18C67.7102 18 73.4766 19.2231 78.7246 21.4336L73.4238 30.6182L82.9629 36.126L88.2588 26.9512C97.4504 33.9379 103.81 44.4557 105.314 56.4844H94.7051V67.5H105.316C103.815 79.5413 97.4473 90.0689 88.2441 97.0586L82.9473 87.8828L73.4082 93.3906L78.709 102.572C73.4651 104.779 67.7043 106 61.6582 106C55.6035 106 49.8348 104.776 44.585 102.563L49.8945 93.3672L40.3555 87.8594L35.0527 97.0439C25.8603 90.0541 19.5005 79.5326 18 67.5H28.6123V56.4844H18.002C19.5071 44.4491 25.8735 33.9262 35.0732 26.9395L40.3721 36.1172L49.9121 30.6104L44.6094 21.4258C49.8527 19.2199 55.6129 18.0001 61.6582 18Z" fill="#1E1E1E"/>
                                </svg>
                            </div>

                            <!-- Mobile Domain Title -->
                            <div class="text-center">
                                <h1 class="${config.title === "COMPETITIVE CODING" ? "text-sm font-normal" : "text-base font-normal"} text-[#1E1E1E] tracking-wider">
                                    ${config.title}
                                </h1>
                            </div>
                        </div>
                    </div>

                    <!-- Mobile Tech Stack Icons -->
                    ${config.techIcons.length > 0 ? `
                        <div class="flex justify-center items-center gap-4 mb-8 flex-wrap px-4">
                            ${config.techIcons.map((icon: any) => `
                                <div class="flex items-center justify-center hover:scale-110 transition-transform duration-300">
                                    <img 
                                        src="${icon.src}" 
                                        alt="${icon.alt}" 
                                        class="w-8 h-8 grayscale hover:grayscale-0 transition-all duration-300 opacity-70 hover:opacity-100" 
                                    />
                                </div>
                            `).join('')}
                        </div>
                    ` : ''}

                    <!-- Mobile Description -->
                    <div class="max-w-sm mx-auto text-center mb-8">
                        <p class="text-[#FEFCD9] text-sm leading-relaxed">
                            ${config.description}
                        </p>
                    </div>

                    <!-- Mobile Projects Button -->
                    <div class="flex justify-center mb-8">
                        <button 
                            class="flex justify-center items-center px-6 py-3 h-[40px] rounded-[25px] border border-[#FEFCD9] font-medium hover:shadow-lg transition-shadow whitespace-nowrap ${config.themeColor === 'competitive' || config.themeColor === 'research' || config.themeColor === 'web' ? 'text-black' : 'text-white'}"
                            style="background-color: ${themeHex}"
                        >
                            ${config.buttonText}
                        </button>
                    </div>

                    <!-- Mobile Cassette SVGs -->
                    <div class="flex justify-center items-center gap-4 mb-8">
                        <div class="flex items-center justify-center">
                            <img 
                                src="${config.cassetteSvg}" 
                                alt="${config.title} Cassette" 
                                class="w-32 h-auto hover:scale-105 transition-transform duration-300" 
                            />
                        </div>
                        <div class="flex items-center justify-center">
                            <img 
                                src="/Cassette_Design.svg" 
                                alt="Design Cassette" 
                                class="w-32 h-auto hover:scale-105 transition-transform duration-300 opacity-60" 
                            />
                        </div>
                    </div>
                </div>
            </div>
        `;
    }

    // Global function to hide mobile domain screen
    (window as any).hideMobileDomainScreen = function() {
        const domainScreen = document.getElementById('mobile-domain-screen');
        
        if (domainScreen) {
            (domainScreen as HTMLElement).style.transition = 'opacity 0.3s ease, transform 0.3s ease';
            (domainScreen as HTMLElement).style.opacity = '0';
            (domainScreen as HTMLElement).style.transform = 'translateY(20px)';
            
            setTimeout(() => {
                domainScreen.remove();
                
                // Restore cassettes and subtitle with staggered animation
                const items = document.querySelectorAll('.mobile-domain-item');
                const subtitle = document.querySelector('.mobile-section-subtitle');
                
                // Show subtitle first
                if (subtitle) {
                    (subtitle as HTMLElement).style.transition = 'opacity 0.4s ease';
                    (subtitle as HTMLElement).style.opacity = '1';
                }
                
                // Then show cassettes with stagger
                items.forEach((item, index) => {
                    setTimeout(() => {
                        (item as HTMLElement).style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                        (item as HTMLElement).style.opacity = '1';
                        (item as HTMLElement).style.transform = 'translateY(0) scale(1)';
                    }, index * 100 + 200);
                });
            }, 300);
        }
    }

    // Initialize mobile animations
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMobileAnimation);
    } else {
        initMobileAnimation();
    }
</script>
