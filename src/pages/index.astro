---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
// src/pages/index.astro
 
import SvgRotator from "../components/cassette.astro";
---

<Layout>
  
  <style>
    #viewer { width: 100%; height: 100vh; position: relative; }
    .spacer { height: 100vh; }
  </style>

  <div class="spacer"></div>
  <div id="viewer"></div>
  <div class="spacer"></div>

  <script type="module">
    import { initViewer } from '/src/components/model-gsap.js';
    // Ensure container has height (100vh is fine)
    initViewer('viewer', '/MINImap.glb', {
    endScroll: 4000,
    desiredSize: 2.5,
    cameraDistanceMul: 2.0,
    startX: -3,
    endX: 3,
    showHelpers: true,
    debugMarkers: true
    }); 

  </script>
  <section id="main-screen" class="min-h-[200vh] flex items-center justify-center bg-white">
    <h1 class="text-4xl">Scroll Down 🚀</h1>
  </section>
  
  <!-- Fixed pinning section with proper ScrollTrigger pin setup -->
  <section id="pinned-section" class="h-[200vh] bg-gray-100 relative">
    <div class="w-full h-screen flex items-center justify-start">
      <SvgRotator
        id="hero-rot"
        trigger="#main-screen"
        offset="20%"
        startDeg={120}
        endDeg={-21}
        svgWidth={600}
      />
    </div>
  </section>
</Layout>
