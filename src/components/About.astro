---

<!-- About Sections-->
<div class="about-container w-screen overflow-hidden">
  <!-- About Section 1: -->
  <section
    class="about-section section-1 w-screen h-screen relative bg-[url('/about/about-acmvit.jpeg')] bg-center bg-cover bg-no-repeat"
  >
    <div
      class="svg-container svg-left relative w-[500px] h-[500px] ml-[-50px] mb-[-600px]"
    >
      <img
        src="/about/Cassette.svg"
        alt="Cassette 1"
        class="cassette-svg w-full h-auto origin-bottom-left rotate-[21deg]"
      />
    </div>
    <div
      class="text-container text-right absolute top-1/2 -translate-y-1/2 text-white p-8 left-[50vw] w-[45vw] max-w-[650px]"
    >
      <p class="text-[1.4rem] leading-[1.55] max-w-[520px]">
        ACM-VIT is a student chapter of the Association for Computing Machinery
        at Vellore Institute of Technology. Since our inception, we've been at
        the forefront of technological innovation and education on campus. Our
        chapter focuses on fostering a passion for computing through workshops,
        hackathons, and industry collaborations. We provide students with
        opportunities to expand their technical skills, work on real-world
        projects, and connect with industry professionals, creating a vibrant
        community of future tech leaders.
      </p>
    </div>
  </section>

  <!-- About Section 2:-->
  <section
    class="about-section section-2 w-screen h-screen relative bg-[url('/about/about-vit.jpeg')] bg-center bg-cover bg-no-repeat"
  >
    <div
      class="text-container text-left absolute top-1/2 -translate-y-1/2 text-white p-8 left-[15vw] w-[45vw] max-w-[520px]"
    >
      <p class="text-[1.4rem] leading-[1.55] max-w-[520px]">
        ACM-VIT is a student chapter of the Association for Computing Machinery
        at Vellore Institute of Technology. Since our inception, we've been at
        the forefront of technological innovation and education on campus. Our
        chapter focuses on fostering a passion for computing through workshops,
        hackathons, and industry collaborations. We provide students with
        opportunities to expand their technical skills, work on real-world
        projects, and connect with industry professionals, creating a vibrant
        community of future tech leaders.
      </p>
    </div>
    <div
      class="svg-container svg-right w-[500px] h-[500px] absolute right-0 top-1/2 -translate-y-1/2 mr-[-100px]"
    >
      <img
        src="/about/3.svg"
        alt="Cassette 2"
        class="cassette-svg w-full h-auto origin-bottom-right rotate-[-15deg]"
      />
    </div>
  </section>

  <!-- About Section 3:-->
  <section
    class="about-section section-3 w-screen h-screen relative bg-[url('/about/about-acm.jpeg')] bg-center bg-cover bg-no-repeat"
  >
    <div
      class="svg-container svg-left-two relative w-[500px] h-[500px] ml-[-50px] mb-[200px]"
    >
      <img
        src="/about/2.svg"
        alt="Cassette 3"
        class="cassette-svg w-full h-auto origin-bottom-left rotate-[11deg]"
      />
    </div>
    <div
      class="text-container text-right absolute top-1/2 -translate-y-1/2 text-white p-8 left-[50vw] w-[45vw] max-w-[650px]"
    >
      <h2 class="text-[4rem] mb-8">Excellence</h2>
      <p class="text-[1.4rem] leading-[1.55] max-w-[520px]">
        Striving for excellence in everything we do, from technical projects to
        community events and educational initiatives.
      </p>
    </div>
  </section>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initAnimations() {
    const sections = document.querySelectorAll(".about-section");

    sections.forEach((section) => {
      const cassette = section.querySelector(".cassette-svg");
      const isLeft =
        section.querySelector(".svg-left") ||
        section.querySelector(".svg-left-two");
      const isRight = section.querySelector(".svg-right");

      if (cassette && (isLeft || isRight)) {
        const xStart = isLeft ? -300 : 300;

        //tilt animation
        gsap.from(cassette, {
          x: xStart,
          rotation: 45, //45 degrees
          duration: 1,
          ease: "power2.out",
          scrollTrigger: {
            trigger: section,
            start: "top 80%",
            end: "center center",
            scrub: 1,
            toggleActions: "play none none reverse",
          },
        });
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAnimations);
  } else {
    initAnimations();
  }
</script>
