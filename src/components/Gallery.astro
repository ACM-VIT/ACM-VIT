---
// Gallery.astro
---

<section class="relative min-h-screen w-full overflow-hidden pt-10">
    <!-- Background Text Pattern -->
    <div class="absolute inset-0 opacity-30 grayscale-100 pointer-events-none z-0">
        <img
            src="/gallery-bg-text.svg"
            alt="Background Pattern"
            class="object-cover w-full"
        />
    </div>

    <!-- Main Content Container -->
    <div
        class="w-full z-10 flex flex-col min-h-screen items-center justify-end"
    >
        <!-- Gallery Title -->
        <div
            class="text-center flex flex-col items-center justify-center gap-10"
        >
            <img
                src="/gallery.svg"
                alt="Gallery Title"
                class="object-cover max-w-[60vw] h-full"
            />

            <!-- CTA Button -->
            <button
                class="bg-primary-orange max-w-[85vw] text-white px-4 py-2 md:px-8 md:py-3 rounded-full text-[0.6rem] md:text-xs transition-all duration-300 transform hover:scale-103 hover:cursor-pointer z-10 border-1 border-[#FEFCD9] mb-2"
            >
                <span style="font-family: 'PolySans Trial';" class="z-10"
                    >PROOF WE ACTUALLY DO STUFF - VIEW PHOTOS!</span
                >
            </button>
        </div>

        <!-- Photo Grid/Collage -->
        <div class="w-full z-0">
            <img
                src="/full-core.svg"
                alt="Description of photo 1"
                class="w-full object-cover rounded-lg shadow-lg"
            />
        </div>
    </div>

    <style>
        @font-face {
            font-family: "PolySans Trial";
            src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-NeutralMono.otf")
                format("opentype");
            font-weight: 400;
            font-style: normal;
            font-display: swap;
        }
    </style>
</section>
